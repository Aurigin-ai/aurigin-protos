# Generated TypeScript code & build artifacts
gen/ts/src/
gen/ts/dist/
gen/ts/node_modules/
gen/ts/package-lock.json
gen/ts/*.tgz

# Generated Python code & build artifacts
gen/py/aurigin/
gen/py/twilio/
gen/py/dist/
gen/py/build/
gen/py/*.egg-info/

# Example caches
examples/typescript/node_modules/
examples/typescript/package-lock.json
examples/python/.venv/

# Local audio fixtures (consumers drop their own .wavs here; not committed)
examples/typescript/audio/*.wav
examples/python/audio/*.wav

# Local virtualenvs created during ad-hoc testing
.venv*/

# CodeArtifact / npm credentials (created by `aws codeartifact login`)
.npmrc
.pypirc

# Misc
__pycache__/
*.pyc
.DS_Store
.idea/
.vscode/
