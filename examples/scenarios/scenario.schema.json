{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aurigin.ai/schemas/simulator-scenario-v1.json",
  "title": "Simulator scenario (v1)",
  "type": "object",
  "required": ["version", "scenario", "stream"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 1 },

    "scenario": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
        "description": { "type": "string" }
      }
    },

    "stream": {
      "type": "object",
      "required": ["duration_ms"],
      "additionalProperties": false,
      "properties": {
        "duration_ms": { "type": "integer", "minimum": 0 },
        "chunk_interval_ms": { "type": "integer", "minimum": 1, "default": 100 },
        "sample_rate_hz": { "type": "integer", "minimum": 8000, "default": 16000 },
        "channels": { "type": "integer", "minimum": 1, "maximum": 8, "default": 1 },
        "codec": { "type": "string", "enum": ["pcm_s16le", "mulaw"], "default": "pcm_s16le" }
      }
    },

    "random": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "seed": { "type": "integer" }
      }
    },

    "network": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "base_latency_ms": { "type": "integer", "minimum": 0, "default": 0 },
        "jitter_ms": { "type": "integer", "minimum": 0, "default": 0 },
        "drop_event_probability": { "type": "number", "minimum": 0, "maximum": 1, "default": 0 },
        "duplicate_event_probability": { "type": "number", "minimum": 0, "maximum": 1, "default": 0 },
        "out_of_order_probability": { "type": "number", "minimum": 0, "maximum": 1, "default": 0 }
      }
    },

    "grpc": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "initial_metadata": { "type": "object", "additionalProperties": { "type": "string" } },
        "trailing_metadata": { "type": "object", "additionalProperties": { "type": "string" } },
        "terminate_at_ms": { "type": "integer", "minimum": 0 },
        "status_code": {
          "type": "string",
          "enum": ["OK", "CANCELLED", "UNKNOWN", "INVALID_ARGUMENT", "DEADLINE_EXCEEDED",
                   "NOT_FOUND", "ALREADY_EXISTS", "PERMISSION_DENIED", "RESOURCE_EXHAUSTED",
                   "FAILED_PRECONDITION", "ABORTED", "OUT_OF_RANGE", "UNIMPLEMENTED",
                   "INTERNAL", "UNAVAILABLE", "DATA_LOSS", "UNAUTHENTICATED"]
        },
        "status_message": { "type": "string" }
      }
    },

    "confidence_curve": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["linear", "step", "sigmoid", "noise", "spike", "decay"] },
        "emit_every_ms": { "type": "integer", "minimum": 1, "default": 1000 },
        "label_threshold": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.5 },
        "label_below": { "type": "string", "default": "bonafide" },
        "label_above": { "type": "string", "default": "spoofed" }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "linear" } } },
          "then": {
            "required": ["from", "to"],
            "properties": {
              "from": { "$ref": "#/$defs/curvePoint" },
              "to": { "$ref": "#/$defs/curvePoint" }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "sigmoid" } } },
          "then": {
            "required": ["from", "to"],
            "properties": {
              "from": { "$ref": "#/$defs/curvePoint" },
              "to": { "$ref": "#/$defs/curvePoint" },
              "steepness": { "type": "number", "minimum": 0.1, "default": 8 }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "step" } } },
          "then": {
            "required": ["points"],
            "properties": {
              "points": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/curvePoint" } }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "noise" } } },
          "then": {
            "required": ["base", "amplitude"],
            "properties": {
              "base": { "type": "number", "minimum": 0, "maximum": 1 },
              "amplitude": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "spike" } } },
          "then": {
            "required": ["base", "spikes"],
            "properties": {
              "base": { "type": "number", "minimum": 0, "maximum": 1 },
              "spikes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["at_ms", "fake_probability"],
                  "properties": {
                    "at_ms": { "type": "integer", "minimum": 0 },
                    "fake_probability": { "type": "number", "minimum": 0, "maximum": 1 },
                    "width_ms": { "type": "integer", "minimum": 1, "default": 500 }
                  }
                }
              }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "decay" } } },
          "then": {
            "required": ["from", "half_life_ms"],
            "properties": {
              "from": { "$ref": "#/$defs/curvePoint" },
              "half_life_ms": { "type": "integer", "minimum": 1 }
            }
          }
        }
      ]
    },

    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["at_ms", "type"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "at_ms": { "type": "integer", "minimum": 0 },
          "type": {
            "enum": ["STREAM_STARTED", "CONFIDENCE_UPDATE", "FAKE_DETECTED",
                     "STREAM_ENDED", "ERROR"]
          },
          "payload": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "fake_probability": { "type": "number", "minimum": 0, "maximum": 1 },
              "label": { "type": "string" },
              "reason": { "type": "string" },
              "code": { "type": "string" },
              "message": { "type": "string" }
            }
          }
        }
      }
    }
  },

  "$defs": {
    "curvePoint": {
      "type": "object",
      "required": ["at_ms", "fake_probability"],
      "properties": {
        "at_ms": { "type": "integer", "minimum": 0 },
        "fake_probability": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
