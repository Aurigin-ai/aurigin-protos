# aurigin-protos Python example runner.
#
# Wraps the `uv run server|client|phone-call|phone-call-burst` invocations
# documented in examples/README.md so devs don't need to memorise the CLI
# flags. Deps resolve from public PyPI — no CodeArtifact auth required.
#
# ─── transport / TLS ────────────────────────────────────────────────────────
# Three modes; pick the recipe family that matches your server:
#
#   default recipes (TLS) — `just server` / `just client` / `just phone-call`
#                           Auto-pick up the committed self-signed certs in
#                           ../certs/. Use these when both sides are this
#                           repo's example server.
#
#   `mtls-*` recipes      — same as above + `MTLS=1` so the server requires
#                           a client cert. Use when validating mutual TLS.
#
#   `insecure-*` recipes  — TLS_CA=/dev/null prefixed. Use when hitting a
#                           plaintext gRPC server (a backend-app dev box, a
#                           dfs running locally without TLS, aurigin-router's
#                           simulator on plaintext, …). The default `client`
#                           / `phone-call` recipes will TLS-handshake-fail
#                           against such a server with a cryptic OpenSSL
#                           "WRONG_VERSION_NUMBER" error — reach for the
#                           insecure-* variant instead.
#
# Argument convention:
#   Only structural args (N concurrency, SCENARIO_ID) are positional.
#   Everything else — --target, --audio, --duration, --stagger-ms, --csv,
#   --chunk-ms — is a CLI flag passed through verbatim. The recipes accept
#   any trailing flags via `*FLAGS`, so you never have to remember a
#   positional ordering, and `--audio FILE` can't accidentally land in the
#   wrong slot.
#
# Discoverability:
#   To see the full flag surface accepted by any `*FLAGS` recipe, run
#   `just help ENTRY` (e.g. `just help phone-call-burst`). Or call the
#   entry-point directly with `--help`: `uv run phone-call-burst --help`.
#
# Cheat sheet:
#   just sync                          # uv sync (installs deps)
#   just server                        # scenario-driven simulator on :50051
#   just client                        # client → localhost:50051 (TLS)
#   just client --target 127.0.0.1:50051       # client → custom target
#   just client --csv /tmp/out.csv             # client + CSV export
#   just insecure-client                       # client → plaintext localhost
#   just phone-call                            # paced WAV streamer → localhost (TLS)
#   just phone-call --audio FILE --duration 30 # custom audio + duration
#   just insecure-phone-call                   # ↑ but plaintext
#   just scenarios                             # list available scenarios
#   just call ID                               # phone-call w/ scenario (10s default)
#   just call ID --duration 30                 # phone-call w/ scenario, custom duration
#   just phone-call-burst 5 ID                                   # 5 concurrent calls of `ID`
#   just phone-call-burst 5 ID --stagger-ms 500                  # + 500ms stagger
#   just insecure-phone-call-burst 5                             # 5 plaintext bursts
#   just insecure-phone-call-burst 10 --duration 30 --audio FILE # 10 × 30s of FILE
#   just mtls-server                           # server in mTLS mode
#   just mtls-call ID                          # phone-call in mTLS mode
#   just mtls-phone-call-burst 5 ID            # 5 concurrent mTLS calls
#   just tls                                   # regenerate the committed self-signed certs
#   just smoke                                 # end-to-end pytest
#
# See examples/certs/README.md for the full trust model.

set shell := ["bash", "-cu"]
set dotenv-load := true

[private]
default:
    @just --list --unsorted

# ─── help ────────────────────────────────────────────────────────────────────

# Recipes that take *FLAGS forward every flag verbatim to one of the Python
# entry-points (`client`, `phone-call`, `phone-call-burst`). The canonical
# list of accepted flags + their defaults lives in each entry's argparse.
# This recipe surfaces that list without leaving `just`:
#   just help client                  # client.py flags
#   just help phone-call              # phone_call.py flags
#   just help phone-call-burst        # phone_call_burst.py flags
#   just help server                  # simulator flags
#
# Print the full CLI flag surface for ENTRY (client | phone-call | phone-call-burst | server).
[group('help')]
help ENTRY:
    @uv run {{ENTRY}} --help

# ─── setup ───────────────────────────────────────────────────────────────────

# uv sync — install aurigin-protos + grpcio from public PyPI.
[group('setup')]
sync:
    uv sync

# One-shot: sync deps + run smoke tests.
[group('setup')]
bootstrap:
    @just sync && just smoke

# Wipe .venv/ and pytest/python caches in this dir.
[group('setup')]
clean:
    rm -rf .venv .pytest_cache __pycache__ */__pycache__

# ─── run ─────────────────────────────────────────────────────────────────────

# Stub DeepfakeDetection server on :50051 (fixed bonafide score, no ML).
[group('run')]
server:
    uv run server

# Pass any client.py flag as a trailing argument:
#   just client                                          # default target
#   just client --target 127.0.0.1:50051                 # custom target
#   just client --audio-dir ../audio/fixtures --csv /tmp/out.csv
# Run `uv run client --help` for the full flag surface.
#
# Client → localhost:50051 (TLS); pass any client.py flag.
[group('run')]
client *FLAGS:
    uv run client {{FLAGS}}

# Picks first audio/*.wav by default, 10s @ localhost:50051 (TLS). Pass any
# phone_call.py flag as a trailing argument:
#   just phone-call                                      # defaults
#   just phone-call --target 127.0.0.1:50051             # custom target
#   just phone-call --audio ../audio/fixtures/test_call_silence.wav --duration 30
# Run `uv run phone-call --help` for the full flag surface.
#
# Phone-call sim → localhost:50051 (TLS); pass any phone_call.py flag.
[group('run')]
phone-call *FLAGS:
    uv run phone-call {{FLAGS}}

# ─── scenarios ──────────────────────────────────────────────────────────────

# Uses the same loader the server uses, so the list always matches what the
# server would accept via the x-scenario-id metadata header.
#
# List loadable scenarios as `<id>  <description>`.
[group('scenarios')]
scenarios:
    @uv run python -c "from sim import load_scenarios; ss = load_scenarios('../scenarios'); [print(f'{s.id:38s}  {s.description}') for s in sorted(ss.values(), key=lambda s: s.id)]"

# Defaults to a 10-second call so most curves fire ≥1 analysis even on short
# scenarios. Pass any phone_call.py flag as a trailing argument:
#   just call fake_detected_rising_curve                 # default 10s
#   just call fake_detected_rising_curve --duration 30   # custom duration
#   just call fake_detected_rising_curve --audio ../audio/fixtures/test_call_silence.wav
#
# Phone-call against the local server, requesting a specific scenario.
[group('scenarios')]
call SCENARIO_ID *FLAGS:
    uv run phone-call --scenario-id {{SCENARIO_ID}} {{FLAGS}}

# Open N concurrent calls of the same scenario. With no --stagger-ms (default
# 0) every call fires at the same instant — the canonical thundering-herd
# test. `--stagger-ms 500` spreads start times: call-02 starts 500ms after
# call-01, call-03 1s after, and so on.
#   just phone-call-burst 5 fake_detected_rising_curve
#   just phone-call-burst 5 fake_detected_rising_curve --stagger-ms 500
#   just phone-call-burst 5 fake_detected_rising_curve --stagger-ms 500 --duration 30
#
# Backed by `phone_call_burst.py` — see that module's docstring for the
# multi-call architecture rationale (one channel, N concurrent bidi
# streams, graceful shutdown across all).
#
# N concurrent phone-calls against one scenario; pass any phone_call_burst.py flag.
[group('scenarios')]
phone-call-burst N SCENARIO_ID *FLAGS:
    uv run phone-call-burst --concurrency {{N}} --scenario-id {{SCENARIO_ID}} {{FLAGS}}

# ─── mtls ───────────────────────────────────────────────────────────────────

# These are just `MTLS=1` shortcuts on top of the recipes above. Functionally
# identical to prefixing `MTLS=1` yourself; recipes exist so the path is
# discoverable in `just --list` and aliases stay in sync if the underlying
# recipe signature changes.

# Same as `just server`, but the server demands a client cert (mTLS).
[group('mtls')]
mtls-server:
    MTLS=1 just server

# Same as `just call`, but presents the example client cert.
[group('mtls')]
mtls-call SCENARIO_ID *FLAGS:
    MTLS=1 just call {{SCENARIO_ID}} {{FLAGS}}

# Same as `just phone-call-burst`, but every concurrent stream is mTLS.
[group('mtls')]
mtls-phone-call-burst N SCENARIO_ID *FLAGS:
    MTLS=1 just phone-call-burst {{N}} {{SCENARIO_ID}} {{FLAGS}}

# ─── insecure (plaintext) ────────────────────────────────────────────────────

# Use these when the gRPC server you're hitting does NOT speak TLS — e.g. a
# backend-app dev box, a deepfake-service running locally without certs,
# aurigin-router's plaintext simulator, or any external service that hasn't
# wired up the example certs. The default TLS recipes will fail handshake
# against such servers with a cryptic OpenSSL "WRONG_VERSION_NUMBER" error.
#
# Implementation: TLS_CA=/dev/null. tls.py treats a missing CA file as
# "insecure mode" and skips ssl_channel_credentials, falling back to
# grpc.insecure_channel.

# Defaults to localhost:50051; override with `--target HOST:PORT`. Pass any
# client.py flag as a trailing argument.
#
# Client → plaintext localhost:50051; pass any client.py flag.
[group('insecure')]
insecure-client *FLAGS:
    TLS_CA=/dev/null uv run client {{FLAGS}}

# Defaults to localhost:50051; override with `--target HOST:PORT`. Pass any
# phone_call.py flag as a trailing argument.
#
# Phone-call → plaintext localhost:50051; pass any phone_call.py flag.
[group('insecure')]
insecure-phone-call *FLAGS:
    TLS_CA=/dev/null uv run phone-call {{FLAGS}}

# Only useful if the plaintext server honors x-scenario-id metadata
# (e.g. aurigin-router's simulator). Real backends ignore it.
#
# Phone-call against a plaintext server, requesting a specific scenario.
[group('insecure')]
insecure-call SCENARIO_ID *FLAGS:
    TLS_CA=/dev/null uv run phone-call --scenario-id {{SCENARIO_ID}} {{FLAGS}}

# The recommended way to load-test a real backend (which is typically
# plaintext on internal networks). Only N is positional; everything else is
# a trailing CLI flag so the recipe never silently consumes `--audio`/etc.:
#   just insecure-phone-call-burst 10                                      # 10 × default duration
#   just insecure-phone-call-burst 10 --duration 30                        # 10 × 30s
#   just insecure-phone-call-burst 10 --duration 30 --stagger-ms 500       # + stagger
#   just insecure-phone-call-burst 10 --audio ../audio/fixtures/test_call_silence.wav
#   just insecure-phone-call-burst 10 --target dfs.internal:50051 --csv /tmp/out.csv
#
# N concurrent plaintext calls; pass any phone_call_burst.py flag.
[group('insecure')]
insecure-phone-call-burst N *FLAGS:
    TLS_CA=/dev/null uv run phone-call-burst --concurrency {{N}} {{FLAGS}}

# ─── tls ────────────────────────────────────────────────────────────────────

# DO NOT USE THESE KEYS IN PRODUCTION — they're checked into the public repo.
# Server cert SANs cover localhost, 127.0.0.1, ::1; both certs valid for 100
# years. The server + clients auto-detect ../certs/server.{crt,key} for TLS;
# MTLS=1 additionally activates ../certs/client.{crt,key} on both sides.
#
# Regenerate the committed self-signed example certs (server + client).
[group('tls')]
tls:
    @mkdir -p ../certs
    openssl req -x509 -newkey ec -pkeyopt ec_paramgen_curve:prime256v1 -nodes \
        -keyout ../certs/server.key -out ../certs/server.crt -days 36500 \
        -subj "/CN=aurigin-protos-example/O=Example only — DO NOT USE IN PRODUCTION" \
        -addext "subjectAltName=DNS:localhost,IP:127.0.0.1,IP:::1"
    openssl req -x509 -newkey ec -pkeyopt ec_paramgen_curve:prime256v1 -nodes \
        -keyout ../certs/client.key -out ../certs/client.crt -days 36500 \
        -subj "/CN=aurigin-protos-example-client/O=Example only — DO NOT USE IN PRODUCTION"
    @echo "→ ../certs/server.{crt,key} + ../certs/client.{crt,key} regenerated."
    @echo "  TLS picks up automatically; mTLS picks up when you set MTLS=1."

# ─── test ────────────────────────────────────────────────────────────────────

# End-to-end smoke tests (spawns server + client, asserts output).
[group('test')]
smoke:
    uv run --extra test pytest tests/ -v
