# aurigin-protos Python example runner.
#
# Wraps the `uv run server|client|phone-call` invocations documented in
# examples/README.md so devs don't need to memorise the phone-call CLI flags.
# Deps resolve from public PyPI — no CodeArtifact auth required.
#
# Usage:
#   just sync                    # uv sync (installs aurigin-protos + grpcio)
#   just server                  # run the stub DeepfakeDetection server
#   just client                  # client against default localhost:50051
#   just client 127.0.0.1:50051  # client against any DeepfakeDetection
#                                # implementation (e.g. aurigin-router's
#                                # backend-simulator on :50051)
#   just smoke                   # end-to-end pytest

set shell := ["bash", "-cu"]
set dotenv-load := true

[private]
default:
    @just --list --unsorted

# ─── setup ───────────────────────────────────────────────────────────────────

# uv sync — install aurigin-protos + grpcio from public PyPI.
[group('setup')]
sync:
    uv sync

# One-shot: sync deps + run smoke tests.
[group('setup')]
bootstrap:
    @just sync && just smoke

# Wipe .venv/ and pytest/python caches in this dir.
[group('setup')]
clean:
    rm -rf .venv .pytest_cache __pycache__ */__pycache__

# ─── run ─────────────────────────────────────────────────────────────────────

# Stub DeepfakeDetection server on :50051 (fixed bonafide score, no ML).
[group('run')]
server:
    uv run server

# Client → TARGET (e.g. 127.0.0.1:50051 to hit the backend-simulator).
[group('run')]
client TARGET="localhost:50051":
    uv run client --target {{TARGET}}

# For custom args (--target, --audio, --duration, --fifo, --codec) call
# `uv run phone-call --help` directly — this recipe is the no-arg shortcut.
#
# Phone-call sim — picks first audio/*.wav, 30s @ localhost:50051.
[group('run')]
phone-call:
    uv run phone-call

# ─── test ────────────────────────────────────────────────────────────────────

# End-to-end smoke tests (spawns server + client, asserts output).
[group('test')]
smoke:
    uv run --extra test pytest tests/ -v
